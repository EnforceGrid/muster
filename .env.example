# OpenAI API key — required for LLM-drafted invitations
OPENAI_API_KEY=sk-...

# Model override (optional, defaults to gpt-4o-mini)
# MUSTER_MODEL_ID=gpt-4o-mini

# App name used in CLI and LLM prompts (default: Muster)
# MUSTER_APP_NAME=Muster

# Reply-to domain for correlation tokens (default: muster.example.com)
# MUSTER_DOMAIN=replies.acme.com

# Postgres (default: localhost:5434)
# DATABASE_URL=postgres://muster:muster@localhost:5434/muster

# ── Outbound SMTP (optional — omit to use file outbox in var/outbox/) ──
# MUSTER_SMTP_HOST=smtp.gmail.com
# MUSTER_SMTP_PORT=587
# MUSTER_SMTP_SECURE=false
# MUSTER_SMTP_USER=you@example.com
# MUSTER_SMTP_PASS=app-password-here
# MUSTER_SMTP_FROM=muster@example.com

# ── Inbound IMAP (required for poll-replies) ──
# MUSTER_IMAP_HOST=imap.gmail.com
# MUSTER_IMAP_PORT=993
# MUSTER_IMAP_SECURE=true
# MUSTER_IMAP_USER=replies@example.com
# MUSTER_IMAP_PASS=app-password-here
# MUSTER_IMAP_MAILBOX=INBOX
